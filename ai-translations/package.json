{
  "name": "datocms-plugin-ai-translations",
  "homepage": "https://github.com/datocms/plugins/tree/master/ai-translations#readme",
  "version": "4.0.0",
  "author": "DatoCMS <support@datocms.com>",
  "description": "Translate fields and records directly on DatoCMS using AI",
  "keywords": [
    "datocms",
    "datocms-plugin"
  ],
  "type": "module",
  "datoCmsPlugin": {
    "title": "AI Translations",
    "coverImage": "docs/cover-1200x800.png",
    "previewImage": "docs/preview.mp4",
    "entryPoint": "dist/index.html",
    "permissions": [
      "currentUserAccessToken"
    ]
  },
  "files": [
    "dist",
    "docs"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:manual": "tsx e2e/manual/fork.ts",
    "test:e2e:manual:cleanup": "tsx e2e/manual/cleanup.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report e2e/playwright-report",
    "self-heal": "OPENAI= GEMINI= CLAUDE= claude 'Use the playwright-test-healer agent to run and heal the failing E2E tests on the DeepL lane, but first ask the user if there are any notes they want to provide'",
    "install:browsers": "playwright install chromium",
    "coverage": "vitest run --coverage",
    "lint": "npx @biomejs/biome@2.4.10 lint ./src",
    "lint:fix": "npx @biomejs/biome@2.4.10 lint --write ./src"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.4",
    "@datocms/cma-client-browser": "^5.5.5",
    "@google/generative-ai": "^0.24.1",
    "datocms-plugin-sdk": "2.2.6",
    "datocms-react-ui": "2.2.6",
    "framer-motion": "^12.42.2",
    "locale-codes": "^1.3.1",
    "openai": "^6.48.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-textarea-autosize": "^8.5.9",
    "react-type-animation": "^3.2.0"
  },
  "devDependencies": {
    "@datocms/cma-client-node": "^5.5.3",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^17.4.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "otplib": "^13.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "datocms-react-ui": {
      "react-intersection-observer": "^9.16.0",
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "@datocms/cma-client": "^5.5.5"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
