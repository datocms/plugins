{
  "name": "datocms-plugin-ai-translations",
  "homepage": "https://github.com/datocms/plugins/tree/master/ai-translations#readme",
  "version": "3.7.0",
  "author": "DatoCMS <support@datocms.com>",
  "description": "Translate fields and records directly on DatoCMS using AI",
  "keywords": [
    "datocms",
    "datocms-plugin"
  ],
  "type": "module",
  "datoCmsPlugin": {
    "title": "AI Translations",
    "coverImage": "docs/cover-1200x800.png",
    "previewImage": "docs/preview.mp4",
    "entryPoint": "dist/index.html",
    "permissions": [
      "currentUserAccessToken"
    ]
  },
  "files": [
    "dist",
    "docs"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.4",
    "@datocms/cma-client-browser": "^5.5.5",
    "@google/generative-ai": "^0.24.1",
    "datocms-plugin-sdk": "2.2.6",
    "datocms-react-ui": "2.2.6",
    "framer-motion": "^12.42.2",
    "locale-codes": "^1.3.1",
    "openai": "^6.48.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-textarea-autosize": "^8.5.9",
    "react-type-animation": "^3.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "datocms-react-ui": {
      "react-intersection-observer": "^9.16.0",
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "@datocms/cma-client": "^5.5.5"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
