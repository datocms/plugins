{
  "name": "datocms-plugin-alt-text-ai",
  "homepage": "https://github.com/datocms/plugins/tree/master/alt-text-ai#readme",
  "version": "0.6.0",
  "author": "DatoCMS <support@datocms.com>",
  "description": "Generate alt text with AltText.ai, OpenAI, Anthropic Claude, or Google Gemini",
  "keywords": [
    "datocms",
    "datocms-plugin",
    "ai",
    "alt",
    "media",
    "assets",
    "accessibility",
    "openai",
    "anthropic",
    "claude",
    "gemini"
  ],
  "type": "module",
  "datoCmsPlugin": {
    "title": "Alt Text AI",
    "previewImage": "docs/demo.mp4",
    "coverImage": "docs/cover.png",
    "entryPoint": "dist/index.html",
    "permissions": [
      "currentUserAccessToken"
    ]
  },
  "files": [
    "dist",
    "docs"
  ],
  "dependencies": {
    "@datocms/cma-client-browser": "^5.3.0",
    "datocms-plugin-sdk": "^2.2.2",
    "datocms-react-ui": "^2.2.4",
    "lodash": "^4.17.23",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "datocms-react-ui": {
      "react-intersection-observer": "^9.16.0",
      "react": "$react",
      "react-dom": "$react-dom"
    }
  }
}
