{
  "name": "datocms-plugin-asset-localization-checker",
  "description": "A field extension for single asset fields that shows whether alt text and are title filled in for all used locales. Galleries are not supported.",
  "homepage": "https://github.com/datocms/plugins/tree/master/asset-localization-checker",
  "private": false,
  "version": "0.2.1",
  "author": "DatoCMS <support@datocms.com>",
  "type": "module",
  "keywords": [
    "datocms-plugin"
  ],
  "datoCmsPlugin": {
    "title": "Asset Localization Checker",
    "coverImage": "docs/cover-1200x800.png",
    "previewImage": "docs/preview.png",
    "entryPoint": "dist/index.html",
    "permissions": [
      "currentUserAccessToken"
    ]
  },
  "files": [
    "dist",
    "docs"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@datocms/cma-client-browser": "^4.0.2",
    "datocms-plugin-sdk": "^2.1.1",
    "datocms-react-ui": "^2.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
