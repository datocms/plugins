{
  "name": "datocms-plugin-dall-e-asset-source",
  "description": "Generate images with current OpenAI image models and insert them directly inside your DatoCMS project",
  "version": "0.1.8",
  "private": false,
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "datocms-plugin-sdk": "^2.1.1",
    "datocms-react-ui": "^2.1.4",
    "openai": "^6.25.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-final-form": "^7.0.0"
  },
  "files": [
    "dist",
    "docs"
  ],
  "keywords": [
    "datocms",
    "datocms-plugin",
    "openai",
    "image-generation"
  ],
  "scripts": {
    "build": "tsc -b && vite build",
    "prepublishOnly": "npm run build",
    "dev": "vite",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "cross-env": "^10.1.0",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "datoCmsPlugin": {
    "title": "OpenAI Image Generator",
    "previewImage": "docs/demo.mp4",
    "coverImage": "docs/cover.png",
    "entryPoint": "dist/index.html"
  },
  "type": "module",
  "overrides": {
    "datocms-react-ui": {
      "react-intersection-observer": "^9.16.0",
      "react": "$react",
      "react-dom": "$react-dom"
    }
  }
}
