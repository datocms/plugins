{
  "name": "datocms-plugin-delete-assets-option",
  "homepage": "https://github.com/datocms/plugins/tree/master/delete-assets-option#readme",
  "version": "0.2.6",
  "author": "DatoCMS <support@datocms.com>",
  "description": "Prompts the users to delete assets only referenced in the records they are deleting",
  "keywords": [
    "datocms",
    "datocms-plugin",
    "assets",
    "asset",
    "media",
    "delete"
  ],
  "datoCmsPlugin": {
    "title": "Delete Assets Option",
    "previewImage": "docs/demo.mp4",
    "coverImage": "docs/cover.png",
    "entryPoint": "dist/index.html",
    "permissions": [
      "currentUserAccessToken"
    ]
  },
  "dependencies": {
    "@datocms/cma-client-browser": "^5.3.0",
    "datocms-plugin-sdk": "^2.1.1",
    "datocms-react-ui": "^2.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build",
    "dev": "vite",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  },
  "type": "module",
  "files": [
    "dist",
    "docs"
  ],
  "overrides": {
    "datocms-react-ui": {
      "react-intersection-observer": "^9.16.0",
      "react": "$react",
      "react-dom": "$react-dom"
    }
  }
}
