{
  "name": "datocms-plugin-environment-diffs",
  "description": "Compare schema, content, and media between two environments in the same DatoCMS project.",
  "homepage": "https://github.com/datocms/plugins",
  "private": false,
  "version": "0.1.0",
  "author": "DatoCMS <support@datocms.com>",
  "type": "module",
  "keywords": [
    "datocms",
    "datocms-plugin",
    "environment",
    "diff"
  ],
  "datoCmsPlugin": {
    "title": "Environment diffs",
    "entryPoint": "dist/index.html",
    "permissions": [
      "currentUserAccessToken"
    ]
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@datocms/cma-client-browser": "^5.3.0",
    "datocms-plugin-sdk": "^2.1.1",
    "datocms-react-ui": "^2.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "npm@11.11.0",
  "overrides": {
    "datocms-react-ui": {
      "react-intersection-observer": "^9.16.0",
      "react": "$react",
      "react-dom": "$react-dom"
    }
  }
}
