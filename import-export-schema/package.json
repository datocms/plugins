{
  "name": "datocms-plugin-schema-import-export",
  "description": "Export one or multiple models/block models as JSON files for reimport into another DatoCMS project.",
  "homepage": "https://github.com/datocms/plugins",
  "private": false,
  "version": "0.1.25",
  "author": "Stefano Verna <s.verna@datocms.com>",
  "type": "module",
  "keywords": [
    "datocms-plugin"
  ],
  "datoCmsPlugin": {
    "title": "Schema Import/Export",
    "coverImage": "docs/cover.png",
    "previewImage": "docs/preview.mp4",
    "entryPoint": "dist/index.html",
    "permissions": [
      "currentUserAccessToken"
    ]
  },
  "files": [
    "dist",
    "docs"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "analyze": "ANALYZE=true npm run build",
    "prepublishOnly": "npm run build",
    "format": "npx @biomejs/biome check --unsafe --write ."
  },
  "dependencies": {
    "@datocms/cma-client": "^5.3.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@types/d3-hierarchy": "^3.1.7",
    "@xyflow/react": "^12.10.1",
    "classnames": "^2.5.1",
    "d3-hierarchy": "^3.1.2",
    "d3-timer": "^3.0.1",
    "datocms-plugin-sdk": "^2.1.1",
    "datocms-react-ui": "^2.1.4",
    "emoji-regex": "^10.6.0",
    "final-form": "^5.0.0",
    "lodash-es": "^4.17.23",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-final-form": "^7.0.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "postcss-preset-env": "^11.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^4.5.0"
  },
  "packageManager": "npm@11.11.0",
  "overrides": {
    "datocms-react-ui": {
      "react-intersection-observer": "^9.16.0",
      "react": "$react",
      "react-dom": "$react-dom"
    }
  }
}
