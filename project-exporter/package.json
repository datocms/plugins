{
  "name": "datocms-plugin-project-exporter",
  "homepage": "https://github.com/datocms/plugins/tree/master/project-exporter#readme",
  "version": "1.3.0",
  "author": "DatoCMS <support@datocms.com>",
  "description": "A plugin that allows you to export records and assets from your project directly from your browser",
  "keywords": [
    "datocms",
    "datocms-plugin"
  ],
  "datoCmsPlugin": {
    "title": "Project Exporter",
    "coverImage": "docs/cover.png",
    "previewImage": "docs/preview.mp4",
    "entryPoint": "build/index.html",
    "permissions": [
      "currentUserAccessToken"
    ]
  },
  "dependencies": {
    "@datocms/cma-client-browser": "^5.2.8",
    "datocms-plugin-sdk": "^2.1.1",
    "datocms-react-ui": "^2.1.4",
    "exceljs": "^4.4.0",
    "flat": "^6.0.1",
    "json-2-csv": "^5.5.10",
    "jsontoxml": "^1.0.1",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "test": "vitest",
    "test:ci": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/jsontoxml": "^1.0.6",
    "@types/node": "^25.2.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.22.0+sha512.bf049efe995b28f527fd2b41ae0474ce29186f7edcb3bf545087bd61fbbebb2bf75362d1307fda09c2d288e1e499787ac12d4fcb617a974718a6051f2eee741c"
}
