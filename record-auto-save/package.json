{
  "name": "datocms-plugin-record-auto-save",
  "homepage": "https://github.com/datocms/plugins/tree/master/record-auto-save#readme",
  "version": "0.2.5",
  "author": "DatoCMS <support@datocms.com>",
  "description": "Auto-save your records after a time interval",
  "keywords": [
    "datocms",
    "datocms-plugin",
    "record",
    "save",
    "automation"
  ],
  "datoCmsPlugin": {
    "title": "Record auto-save",
    "previewImage": "docs/demo.mp4",
    "coverImage": "docs/cover.png",
    "entryPoint": "dist/index.html",
    "permissions": []
  },
  "dependencies": {
    "datocms-plugin-sdk": "^2.1.1",
    "datocms-react-ui": "^2.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-select": "^5.10.2"
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build",
    "dev": "vite",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  },
  "type": "module",
  "files": [
    "dist",
    "docs"
  ],
  "overrides": {
    "datocms-react-ui": {
      "react-intersection-observer": "^9.16.0",
      "react": "$react",
      "react-dom": "$react-dom"
    }
  }
}
