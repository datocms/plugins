    "typescript": "^5.9.3",
    "url": "^0.11.4",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@babel/runtime": "^7.28.6",
    "datocms-react-ui": {
      "react-intersection-observer": "^9.16.0",
