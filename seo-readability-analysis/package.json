{
  "name": "datocms-plugin-seo-readability-analysis",
  "homepage": "https://github.com/datocms/plugins/tree/master/seo-readability-analysis#readme",
  "version": "0.1.16",
  "description": "Run SEO/Readability analysis using YoastSEO.js on your frontend everytime you make a change to the content of a record",
  "author": "DatoCMS <support@datocms.com>",
  "license": "GPLv3",
  "files": [
    "docs",
    "dist"
  ],
  "keywords": [
    "datocms",
    "datocms-plugin",
    "field-editor",
    "json-field",
    "seo",
    "analysis",
    "keywords",
    "readability"
  ],
  "private": false,
  "datoCmsPlugin": {
    "title": "SEO/Readability Analysis",
    "previewImage": "docs/video.mp4",
    "coverImage": "docs/cover.png",
    "entryPoint": "dist/index.html"
  },
  "dependencies": {
    "@types/lodash-es": "^4.17.12",
    "datocms-plugin-sdk": "^2.1.1",
    "datocms-react-ui": "^2.1.4",
    "final-form": "^5.0.0",
    "lodash-es": "^4.17.23",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-final-form": "^7.0.0",
    "yoastseo": "^3.6.0"
  },
  "scripts": {
    "build": "npm run build-worker && tsc -b && vite build",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build",
    "dev": "vite",
    "build-worker": "esbuild workerSrc/index.js --bundle --format=iife --outfile=public/main.js",
    "preview": "vite preview"
