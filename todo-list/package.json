{
  "name": "datocms-plugin-todo-list",
  "homepage": "https://github.com/datocms/plugins/tree/master/todo-list#readme",
  "version": "0.0.16",
  "description": "Add To-Do lists to your records sidebar",
  "author": "DatoCMS <support@datocms.com>",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "dist": "npm run build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "test": "echo 1"
  },
  "files": [
    "docs",
    "dist"
  ],
  "keywords": [
    "datocms",
    "datocms-plugin",
    "sidebar"
  ],
  "datoCmsPlugin": {
    "title": "Sidebar Todo lists",
    "previewImage": "docs/demo.gif",
    "coverImage": "docs/cover.png",
    "entryPoint": "dist/index.html",
    "fieldTypes": [
      "json"
    ],
    "parameters": {
      "global": [
        {
          "id": "developmentMode",
          "label": "Development mode?",
          "type": "boolean",
          "hint": "Enable development logs on the console"
        }
      ],
      "instance": [
        {
          "id": "initialTodos",
          "label": "Initial To-Dos",
          "type": "text",
          "hint": "The first To-Dos that will be shown on new records, one per line"
        }
      ]
    }
  },
  "dependencies": {
    "datocms-plugin-sdk": "^2.1.1",
    "datocms-react-ui": "^2.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "datocms-react-ui": {
      "react-intersection-observer": "^9.16.0",
      "react": "$react",
      "react-dom": "$react-dom"
    }
  }
}
